<% layout("layouts/boilerplate") %>

    <div class="row">
        <!-- put whole form in div class=row and class=col-8 to make forms short (8 out of 12) horizontally -->
        <div class="col-8 offset-2"> <!-- offset-2 shifts whole div right by 2 -->
            <br>
            <h3>Create a New List</h3>
            <br>

            <form method="POST" action="/listings">
                <!-- <input name="title" placeholder="Enter your title here" type="text">
        <br><br>
        <textarea name="description" placeholder="description" type="text"></textarea>
        <br><br>
        <input name="Image" placeholder="Enter image url" type="text">
        <br><br>
        <input name="price" placeholder="Enter price" type="number">
        <br><br>
        <input name="location" placeholder="location of listing" type="text">
        <br><br>
        <input name="country" placeholder="country" type="text">
        <br><br> -->

                <!-- create an object listing with keys = title,description,image,price,location,country -->

                <div class="mb-3"> <!-- class="mb-3" gives breathing space b/w inputs -->
                    <label for="title" class="form-label">Title</label>
                    <input name="listing[title]" placeholder="Your Catchy title" type="text" class="form-control">
                </div>
                <div class="mb-3">
                    <label for="description" class="form-label">description</label>
                    <textarea name="listing[description]" class="form-control"></textarea>
                </div>

                <div class="mb-3">
                    <label for="image" class="form-label">Image Link</label>
                    <input name="listing[image]" placeholder="Enter image url" type="text" class="form-control">
                </div>

                <!-- to put section of price and row in 1 row -->
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <!-- to divide horizontal space of 12 only on medium or greater than medium screen-->
                        <label for="price" class="form-label">Price</label>
                        <input name="listing[price]" placeholder="1500" type="number" class="form-control">
                    </div>

                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input name="listing[country]" placeholder="India" type="text" class="form-control">
                    </div>
                </div>


                <div class="mb-3">
                    <label for="location" class="form-label">Location</label>
                    <input name="listing[location]" placeholder="Jaipur,Rajasthan" type="text" class="form-control">
                </div>

                <button type="submit" class="btn btn-dark add-btn">Add</button>
                <br>
                <br>
            </form>
        </div>
    </div>
