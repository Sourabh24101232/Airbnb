          <!-- create an object listing with keys = title,description,image,price,location,country -->
        <input name="listing[title]" placeholder="Enter your title here" type="text">
        <br><br>
        <textarea name="listing[description]" placeholder="description"></textarea>
        <br><br>
        <input name="listing[image]" placeholder="Enter image url" type="text">
        <br><br>
        <input name="listing[price]" placeholder="Enter price" type="number">
        <br><br>
        <input name="listing[location]" placeholder="location of listing" type="text">
        <br><br>
        <input name="listing[country]" placeholder="country" type="text">
        <br><br>

        <button type="submit">Add</button>
    </form>
